# TokenRouter (required) — Claude Opus 4.7 access
TOKENROUTER_API_KEY=sk-...
# TokenRouter base URL. The default below assumes an OpenAI-compatible /v1 endpoint.
# Override if TokenRouter publishes a different host or path.
TOKENROUTER_BASE_URL=https://api.tokenrouter.ai/v1
# Exact model identifier supplied to the API
TOKENROUTER_MODEL=tokenrouter/anthropic/claude-opus-4.7

# Tavily web search (required for the web_search tool)
TAVILY_API_KEY=tvly-...

# Optional: custom User-Agent used by Reddit/Wikipedia/Nominatim clients
STRAW_HATS_USER_AGENT=straw-hats-treasure-agent/0.1 (contact: you@example.com)
